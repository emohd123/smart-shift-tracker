<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Work Experience Certificate</title>
  <link rel="stylesheet" href="./styles.css" />
</head>
<body>
  <div class="outer-frame"></div>
  <div class="inner-frame"></div>
  <div class="watermark"></div>

  <div class="content">
    <!-- Header -->
    <header class="cert-header">
      <div class="header-title">Certificate</div>
      <div class="header-subtitle">of Employment</div>
      <div class="header-line"></div>
      <div class="header-ornament">&#9670; &#9670; &#9670;</div>
    </header>

    <!-- Main Body -->
    <main class="main-body">
      <!-- Left Column: Promoter Info -->
      <div class="left-column">
        <div class="photo-frame">
          {{#if partTimer.photoDataUri}}
            <img src="{{partTimer.photoDataUri}}" alt="Promoter photo">
          {{else}}
            <div class="photo-placeholder">{{partTimer.initials}}</div>
          {{/if}}
        </div>
        <div class="promoter-name">{{partTimer.fullName}}</div>
        <div class="promoter-role">{{partTimer.roleLabel}}</div>
        <div class="info-panel">
          <strong>Nationality:</strong> {{partTimer.nationality}}<br>
          <strong>Code:</strong> {{partTimer.promoCode}}<br>
          <strong>Phone:</strong> {{partTimer.phone}}<br>
          <strong>Email:</strong> {{partTimer.email}}<br>
          <strong>Issued:</strong> {{certificate.issueDate}}
        </div>
      </div>

      <!-- Right Column: Companies and Work Details -->
      <div class="right-column">
        <!-- Multi-company support -->
        {{#if employers}}
          {{#each employers}}
            <div class="company-section">
              <div class="company-name">{{this.employer.name}}</div>
              <div class="company-industry">{{this.employer.industry}}</div>
              <div class="company-details">
                {{#if this.employer.website}}Website: {{this.employer.website}}<br>{{/if}}
                {{#if this.employer.email}}Email: {{this.employer.email}}<br>{{/if}}
                {{#if this.employer.registration}}CR/Reg. No: {{this.employer.registration}}<br>{{/if}}
              </div>
              <div class="verified-badge">VERIFIED EMPLOYER</div>
            </div>

            <div class="work-section">
              <div class="section-heading">Work Assignments</div>
              <table>
                <thead>
                  <tr>
                    <th>Event / Campaign</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th style="text-align:right">Hours</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each this.assignments}}
                    <tr>
                      <td>{{this.event}}</td>
                      <td>{{this.date}}</td>
                      <td>{{this.location}}</td>
                      <td class="hours-cell">{{this.hours}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{/each}}
        {{else}}
          <!-- Single company fallback -->
          <div class="company-section">
            <div class="company-name">{{employer.name}}</div>
            <div class="company-industry">{{employer.industry}}</div>
            <div class="company-details">
              {{#if employer.website}}Website: {{employer.website}}<br>{{/if}}
              {{#if employer.email}}Email: {{employer.email}}<br>{{/if}}
              {{#if employer.registration}}CR/Reg. No: {{employer.registration}}<br>{{/if}}
            </div>
            <div class="verified-badge">VERIFIED EMPLOYER</div>
          </div>

          <div class="work-section">
            <div class="section-heading">Work Assignments</div>
            <table>
              <thead>
                <tr>
                  <th>Event / Campaign</th>
                  <th>Date</th>
                  <th>Location</th>
                  <th style="text-align:right">Hours</th>
                </tr>
              </thead>
              <tbody>
                {{#each assignments}}
                  <tr>
                    <td>{{this.event}}</td>
                    <td>{{this.date}}</td>
                    <td>{{this.location}}</td>
                    <td class="hours-cell">{{this.hours}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{/if}}

        <!-- Total Hours Box -->
        <div class="total-box">
          <div class="total-label">Total Verified Work Experience</div>
          <div class="total-value">{{summary.totalHours}} {{summary.hoursLabel}}</div>
          <div class="total-org">Across {{summary.companyCount}} organization{{#ifCond summary.companyCount '>' 1}}s{{/ifCond}}</div>
        </div>
      </div>
    </main>

    <!-- Bottom Section -->
    <section class="bottom-section">
      <div class="qr-area">
        {{#if certificate.qrDataUri}}
          <img class="qr-code" src="{{certificate.qrDataUri}}" alt="QR Code">
        {{else}}
          <div class="qr-placeholder">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="10" width="25" height="25" fill="#0d2137"/>
              <rect x="65" y="10" width="25" height="25" fill="#0d2137"/>
              <rect x="10" y="65" width="25" height="25" fill="#0d2137"/>
              <rect x="40" y="40" width="20" height="20" fill="#b8860b"/>
              <rect x="15" y="15" width="15" height="15" fill="white"/>
              <rect x="70" y="15" width="15" height="15" fill="white"/>
              <rect x="15" y="70" width="15" height="15" fill="white"/>
              <rect x="42" y="42" width="16" height="16" fill="white"/>
              <rect x="45" y="45" width="10" height="10" fill="#0d2137"/>
              <rect x="40" y="10" width="5" height="5" fill="#0d2137"/>
              <rect x="50" y="10" width="5" height="5" fill="#0d2137"/>
              <rect x="40" y="20" width="5" height="5" fill="#0d2137"/>
              <rect x="55" y="20" width="5" height="5" fill="#0d2137"/>
              <rect x="10" y="40" width="5" height="5" fill="#0d2137"/>
              <rect x="20" y="45" width="5" height="5" fill="#0d2137"/>
              <rect x="10" y="55" width="5" height="5" fill="#0d2137"/>
              <rect x="65" y="40" width="5" height="5" fill="#0d2137"/>
              <rect x="75" y="45" width="5" height="5" fill="#0d2137"/>
              <rect x="85" y="50" width="5" height="5" fill="#0d2137"/>
              <rect x="65" y="55" width="5" height="5" fill="#0d2137"/>
              <rect x="75" y="65" width="5" height="5" fill="#0d2137"/>
              <rect x="85" y="70" width="5" height="5" fill="#0d2137"/>
              <rect x="65" y="75" width="5" height="5" fill="#0d2137"/>
              <rect x="85" y="85" width="5" height="5" fill="#0d2137"/>
              <rect x="40" y="65" width="5" height="5" fill="#0d2137"/>
              <rect x="50" y="70" width="5" height="5" fill="#0d2137"/>
              <rect x="40" y="80" width="5" height="5" fill="#0d2137"/>
              <rect x="55" y="85" width="5" height="5" fill="#0d2137"/>
              <rect x="50" y="55" width="5" height="5" fill="#0d2137"/>
            </svg>
          </div>
        {{/if}}
        <div class="qr-label">Scan to Verify</div>
      </div>

      <div class="signature-area">
        <div class="seal">
          <div class="seal-inner">
            <div class="seal-text">Official<br>Seal</div>
          </div>
        </div>
        <div class="sig-line"></div>
        <div class="sig-label">Authorized Signature</div>
      </div>

      <div class="date-area">
        <div class="date-label">Date of Issue</div>
        <div class="date-value">{{certificate.issueDate}}</div>
        <div class="ref-number">{{certificate.ref}}</div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <span class="footer-brand">{{brand.name}}</span> &mdash; This certificate was generated digitally and is verifiable via QR code or online at {{brand.verifyUrl}}
  </footer>
</body>
</html>