<!-- Professional Certificate Template
     Navy & Gold Theme - Formal Document Aesthetic
-->
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <!-- Frame borders -->
  <div class="outer-frame"></div>
  <div class="inner-frame"></div>

  <!-- Watermark pattern -->
  <div class="watermark"></div>

  <!-- Main content -->
  <div class="content">

    <!-- Certificate Header -->
    <div class="cert-header">
      <div class="header-title">CERTIFICATE</div>
      <div class="header-subtitle">of Employment</div>
      <div class="header-line"></div>
      <div class="header-ornament">&#9670; &#9670; &#9670;</div>
    </div>

    <!-- Two-Column Body -->
    <div class="main-body">

      <!-- LEFT COLUMN -->
      <div class="left-column">

        <!-- Photo -->
        <div class="photo-frame">
          {{#if photoUrl}}
            <img src="{{photoUrl}}" alt="Employee Photo" />
          {{else}}
            <span class="photo-placeholder">{{initials}}</span>
          {{/if}}
        </div>

        <!-- Name -->
        <div class="promoter-name">{{promoterName}}</div>
        <div class="promoter-role">{{position}}</div>

        <!-- Info Panel -->
        <div class="info-panel">
          <div><strong>Nationality:</strong> {{nationality}}</div>
          <div><strong>Code:</strong> {{code}}</div>
          <div><strong>Phone:</strong> {{phone}}</div>
          <div><strong>Email:</strong> {{email}}</div>
          <div><strong>Issued:</strong> {{issueDate}}</div>
        </div>

      </div>

      <!-- RIGHT COLUMN -->
      <div class="right-column">

        <!-- Company Section -->
        <div class="company-section">
          <div class="company-name">{{companyName}}</div>
          <div class="company-industry">{{companyIndustry}}</div>
          <div class="company-details">
            Website: {{companyWebsite}}<br/>
            Email: {{companyEmail}}<br/>
            CR/Reg. No: {{companyRegistration}}
          </div>
          <div class="verified-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            VERIFIED EMPLOYER
          </div>
        </div>

        <!-- Work Assignments -->
        <div class="work-section">
          <div class="section-heading">Work Assignments</div>
          <table>
            <thead>
              <tr>
                <th>Event / Campaign</th>
                <th>Date</th>
                <th>Location</th>
                <th>Hours</th>
              </tr>
            </thead>
            <tbody>
              {{#each assignments}}
              <tr>
                <td class="event-cell">{{this.event}}</td>
                <td>{{this.date}}</td>
                <td class="location-cell">{{this.location}}</td>
                <td class="hours-cell">{{this.hours}}h</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <!-- Total Hours -->
        <div class="total-box">
          <div class="total-label">TOTAL VERIFIED WORK EXPERIENCE</div>
          <div class="total-value">{{totalHours}} {{#ifEquals totalHours 1}}Hour{{else}}Hours{{/ifEquals}}</div>
          <div class="total-org">Across {{organizationCount}} organization{{#ifEquals organizationCount 1}}{{else}}s{{/ifEquals}}</div>
        </div>

      </div>
    </div>

    <!-- Bottom Section -->
    <div class="bottom-section">

      <!-- QR Code -->
      <div class="qr-area">
        {{#if qrCodeUrl}}
          <img class="qr-code" src="{{qrCodeUrl}}" alt="QR Code" />
        {{else}}
          <div class="qr-placeholder">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="10" width="30" height="30" fill="#1a1a2e"/>
              <rect x="60" y="10" width="30" height="30" fill="#1a1a2e"/>
              <rect x="10" y="60" width="30" height="30" fill="#1a1a2e"/>
              <rect x="45" y="45" width="10" height="10" fill="#c9a84c"/>
              <rect x="60" y="60" width="10" height="10" fill="#c9a84c"/>
              <rect x="80" y="60" width="10" height="10" fill="#c9a84c"/>
              <rect x="60" y="80" width="10" height="10" fill="#c9a84c"/>
              <rect x="80" y="80" width="10" height="10" fill="#c9a84c"/>
            </svg>
          </div>
        {{/if}}
        <div class="qr-label">Scan to Verify</div>
      </div>

      <!-- Signature -->
      <div class="signature-area">
        <div class="seal">
          <div class="seal-inner">
            <span class="seal-text">OFFICIAL<br/>SEAL</span>
          </div>
        </div>
        <div class="sig-line"></div>
        <div class="sig-label">Authorized Signature</div>
      </div>

      <!-- Date -->
      <div class="date-area">
        <div class="date-label">Date of Issue</div>
        <div class="date-value">{{issueDate}}</div>
        <div class="ref-number">{{referenceNumber}}</div>
      </div>

    </div>

    <!-- Footer -->
    <div class="footer">
      <span class="footer-brand">{{brandName}}</span> — This certificate was generated digitally and is verifiable via QR code or online at {{verifyUrl}}
    </div>

  </div>
</body>
</html>